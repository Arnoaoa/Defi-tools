# Telegram bot — generate via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# RPC providers
ALCHEMY_API_KEY=
ANKR_API_KEY=

# Per-chain RPC URLs (used by Pendle adapter and Morpho on-chain fallback)
ALCHEMY_ETH_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_ARB_URL=https://arb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_OPT_URL=https://opt-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ANKR_AVAX_URL=https://rpc.ankr.com/avalanche

# The Graph decentralized network (Aave V3 subgraph queries)
# Get a free key at https://thegraph.com/studio/apikeys/
GRAPH_API_KEY=

# Optional — price oracle backup
COINGECKO_API_KEY=

# Monitor config
MONITOR_LOG_LEVEL=INFO
MONITOR_DB_PATH=./data/monitor.sqlite
MONITOR_HEARTBEAT_PATH=./data/last_heartbeat.txt

# API server (dashboard)
API_HOST=127.0.0.1
API_PORT=8000
DASHBOARD_ORIGIN=http://localhost:3000
