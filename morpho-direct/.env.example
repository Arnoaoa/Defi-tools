# Optional: custom RPC endpoints (defaults to public RPCs if unset)
NEXT_PUBLIC_ETH_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=

# Daily lending alerts cron (/api/cron/alerts)
# Telegram bot created via @BotFather
TELEGRAM_BOT_TOKEN=
# Your personal chat id (send /start to the bot, then call getUpdates)
TELEGRAM_CHAT_ID=
# Wallet whose Morpho lending positions are monitored
MONITORED_ADDRESS=
# Shared secret protecting the cron route (set the same value in Vercel)
CRON_SECRET=
